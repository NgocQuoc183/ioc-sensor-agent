# Thông tin thiết bị
DEVICE_ID=raspberry-pi-01
TIMEZONE=Asia/Ho_Chi_Minh

# API server
API_BASE_URL=http://YOUR_SERVER
# Chu kỳ gửi dữ liệu (milliseconds), mặc định 60000 = 1 phút
POLL_INTERVAL_MS=60000

# Địa chỉ I2C
SHT31_ADDRESS=0x44
ADS1115_ADDRESS=0x48

# Hệ số hiệu chuẩn pH (tùy theo bộ cảm biến, cần đo thực tế)
PH_CALIBRATION_OFFSET=0.0
PH_CALIBRATION_SLOPE=1.0

# Hệ số hiệu chuẩn TDS
TDS_TEMPERATURE=25.0

# GPIO bus I2C
I2C_BUS=1
